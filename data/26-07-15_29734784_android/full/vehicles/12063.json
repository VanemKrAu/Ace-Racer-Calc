      "passive_skill_rich_desc": "42",
      "slipstream": "跟随在车辆后方将获得尾流，产生持续的氮气充能效果",
      "special_passive_skill_desc": {
        "raw": "每次使用大招时极速+5km/h（上限叠加至30km/h）并#tips[净化]友方全体负面效果",
        "html": "每次使用大招时极速+5km/h（上限叠加至30km/h）并<span class=\"rt-tip rt-tip--entry\" data-tip=\"净化\" data-icon=\"carport_new_skill_illustrate_b9\" data-desc=\"·解除持续性的负面效果\" style=\"--tip-color:#7eedff\" title=\"·解除持续性的负面效果\"><span class=\"rt-tip__icon-slot\"></span>净化</span>友方全体负面效果"
      },
      "special_passive_skill_icon": "new_carport_icon_10324",
      "special_passive_skill_title": "弥难",
      "title_ace_time_charge_condition": "赛道专精",
      "title_ace_time_effect": "RECU限制解除",
      "title_slipstream": "空气动力学套件",
      "title_unlock_nitro_2": "大招强化套件 I",
      "title_unlock_nitro_3": "竞速级氮气支架",
      "unlock_nitro_3": "解锁1x6磅，2x3磅，3x2磅氮气",
      "upgrade_level_icon": "new_carport_icon_10324",
      "feature_desc": {
        "raw": "加速推进，极速提升#desc[1437]，持续7秒。开启大招时：\n·获得一个涡轮和3500集气量\n·期间首次使用的涡轮或氮气视为对360米范围内每名敌方下一次按键的预测\n·每次预测成功将#tips[封禁]这名敌方对应的按键6秒。",
        "html": "加速推进，极速提升<span class=\"rt-desc\">极速提升 50km/h</span>，持续7秒。开启大招时：<br/>·获得一个涡轮和3500集气量<br/>·期间首次使用的涡轮或氮气视为对360米范围内每名敌方下一次按键的预测<br/>·每次预测成功将<span class=\"rt-tip rt-tip--entry\" data-tip=\"封禁\" data-icon=\"carport_new_skill_illustrate_r3\" data-desc=\"·持续时间内无法使用对应的功能\" style=\"--tip-color:#ffa8b1\" title=\"·持续时间内无法使用对应的功能\"><span class=\"rt-tip__icon-slot\"></span>封禁</span>这名敌方对应的按键6秒。"
      },
      "sp_skill_desc": null,
      "passive_skill_desc": null,
      "story_title": "厂商：混沌",
      "story": {
        "raw": "阿波罗的外观设计灵感来源于希腊神话中的光明之神阿波罗，象征着光明与智慧。阿波罗具有预言之力，能够预测其他车辆的运动轨迹，轻松应对各种挑战，成为赛道上的不败神话。",
        "html": "阿波罗的外观设计灵感来源于希腊神话中的光明之神阿波罗，象征着光明与智慧。阿波罗具有预言之力，能够预测其他车辆的运动轨迹，轻松应对各种挑战，成为赛道上的不败神话。"
      }
    },
