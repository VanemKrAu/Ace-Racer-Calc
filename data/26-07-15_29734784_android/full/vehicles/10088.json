      "upgrade_level_icon": "new_carport_icon_10177",
      "feature_desc": {
        "raw": "иҺ·еҫ—зҲҶеҸ‘еҠ йҖҹпјҢжһҒйҖҹжҸҗеҚҮ#desc[208]пјҢжҢҒз»ӯ6з§’гҖӮеҠ йҖҹжңҹй—ҙиҪҰиҫҶ#tips[ж— жі•йҖүдёӯ]гҖӮ",
        "html": "иҺ·еҫ—зҲҶеҸ‘еҠ йҖҹпјҢжһҒйҖҹжҸҗеҚҮ<span class=\"rt-desc\">жһҒйҖҹжҸҗеҚҮ 50km/h</span>пјҢжҢҒз»ӯ6з§’гҖӮеҠ йҖҹжңҹй—ҙиҪҰиҫҶ<span class=\"rt-tip rt-tip--entry\" data-tip=\"ж— жі•йҖүдёӯ\" data-icon=\"carport_new_skill_illustrate_y12\" data-desc=\"В·ж— жі•жҲҗдёәе№Іжү°жҲ–иҖ…иҫ…еҠ©ж•Ҳжһңзҡ„зӣ®ж Ү&#10;В·е·Із»ҸиҺ·еҫ—зҡ„е№Іжү°гҖҒиҫ…еҠ©зҠ¶жҖҒдёҚдјҡиў«еҪұе“Қ\" style=\"--tip-color:#ffd700\" title=\"В·ж— жі•жҲҗдёәе№Іжү°жҲ–иҖ…иҫ…еҠ©ж•Ҳжһңзҡ„зӣ®ж Ү&#10;В·е·Із»ҸиҺ·еҫ—зҡ„е№Іжү°гҖҒиҫ…еҠ©зҠ¶жҖҒдёҚдјҡиў«еҪұе“Қ\"><span class=\"rt-tip__icon-slot\"></span>ж— жі•йҖүдёӯ</span>гҖӮ"
      },
      "sp_skill_desc": null,
      "passive_skill_desc": null,
      "story_title": "еҺӮе•ҶпјҡеҘҘиҝӘ",
